{
  "name": "ronin",
  "version": "5.1.3",
  "type": "module",
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": "./dist/bin/index.js",
  "description": "Access the RONIN data platform via TypeScript.",
  "scripts": {
    "dev": "bun run build -- --watch",
    "build": "tsup",
    "test": "bun test",
    "lint": "bun run --bun lint:tsc && bun run --bun lint:biome",
    "lint:biome": "biome check",
    "lint:tsc": "tsc --pretty",
    "prepare": "husky && bun run build",
    "format": "biome format --write"
  },
  "files": [
    "dist"
  ],
  "repository": "ronin-co/client",
  "homepage": "https://ronin.co/docs/typescript-client",
  "keywords": [
    "ronin",
    "client",
    "database",
    "orm",
    "edge",
    "serverless"
  ],
  "lint-staged": {
    "**/*": [
      "biome check"
    ]
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./schema": {
      "import": "./dist/schema/index.js",
      "types": "./dist/schema/index.d.ts"
    },
    "./utils": {
      "import": "./dist/utils/index.js",
      "types": "./dist/utils/index.d.ts"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "dist/index.d.ts"
      ],
      "types": [
        "dist/types/index.d.ts"
      ],
      "schema": [
        "dist/schema/index.d.ts"
      ],
      "utils": [
        "dist/utils/index.d.ts"
      ]
    }
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "dependencies": {
    "@iarna/toml": "2.2.5",
    "@inquirer/prompts": "7.0.1",
    "@paralleldrive/cuid2": "2.2.2",
    "@ronin/compiler": "0.12.3",
    "chalk-template": "1.1.0",
    "get-port": "7.1.0",
    "ini": "5.0.0",
    "json5": "2.2.3",
    "open": "10.1.0",
    "ora": "8.1.0",
    "pluralize": "8.0.0",
    "typescript": "5.6.3",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@ronin/schemas": "0.1.5",
    "@types/bun": "1.1.12",
    "@types/ini": "4.1.1",
    "@types/pluralize": "0.0.33",
    "husky": "9.1.6",
    "lint-staged": "15.2.10",
    "tsup": "8.3.5"
  }
}
